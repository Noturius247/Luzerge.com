# ============================================================
# Luzerge.com — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it's gitignored.
# ============================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=your-database-password

# ─── Cloudflare ──────────────────────────────────────────────────────────────
# Zone ID: Cloudflare Dashboard → your domain → Overview (right sidebar)
# API Token: My Profile → API Tokens → Create Token (Cache Purge permission)
CLOUDFLARE_ZONE_ID=abc123def456abc123def456abc12345
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL=hello@luzerge.com

# ─── Site ────────────────────────────────────────────────────────────────────
SITE_URL=https://luzerge.com
ENVIRONMENT=development
